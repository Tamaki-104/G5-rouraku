# ============================================================
# 環境変数サンプル
# このファイルを .env としてコピーし、値を埋めてください（.env は Git 管理対象外）。
# ============================================================

# true: モックデータ/モックAIで動作（キー不要）
# false: Supabase / Gemini に本接続（キー必須）
USE_MOCK=false

# Flask セッション署名キー（任意の長いランダム文字列。本番は必ず設定）
FLASK_SECRET_KEY=please-change-this-to-a-random-string

# --- Supabase（USE_MOCK=false のとき必須）---
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...

# --- Gemini API（任意。未設定ならAIはモック応答にフォールバック）---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
