# ============================================================
# 環境変数サンプル
# このファイルを .env としてコピーし、値を設定する（.env は Git 管理対象外）。
# ============================================================

# true: モックデータで動作（キー不要） / false: Supabase に本接続
USE_MOCK=false

# Flask セッション署名キー（任意の長いランダム文字列。本番は必ず設定）
FLASK_SECRET_KEY=please-change-this-to-a-random-string

# --- Supabase（USE_MOCK=false のとき必須）---
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=sb_publishable_...

# --- Gemini API（未設定の場合、AIはモック応答で動作）---
GEMINI_API_KEY=
# 既定は無料枠が広い flash-lite。上位品質は gemini-2.5-flash（無料枠の1日上限は小さい）
GEMINI_MODEL=gemini-2.5-flash-lite
